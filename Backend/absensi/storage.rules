rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isHC() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "HC"
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == "ACTIVE";
    }

    match /attendance_photos/{userId}/{allPaths=**} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || isHC()
        );

      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /permission_proofs/{userId}/{allPaths=**} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || isHC()
        );

      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches("image/.*")
          || request.resource.contentType == "application/pdf"
          || request.resource.contentType.matches("application/.*")
        );
    }

    match /working_report_files/{userId}/{allPaths=**} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || isHC()
        );

      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
