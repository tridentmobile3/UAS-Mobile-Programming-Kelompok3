rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isHC() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "HC"
        && userDoc().data.status == "ACTIVE";
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isHC();

      allow create: if false;

      allow update: if isHC()
        || (
          isSelf(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["fcmToken", "photoProfileUrl", "updatedAt"])
        );

      allow delete: if false;
    }

    match /office_locations/{locationId} {
      allow read: if signedIn();
      allow write: if isHC();
    }

    match /attendances/{attendanceId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isHC()
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isLocked == true;

      allow update: if (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.date == resource.data.date
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              "checkOutTime",
              "checkOutLatitude",
              "checkOutLongitude",
              "checkOutAccuracy",
              "checkOutDistance",
              "checkOutPhotoUrl",
              "updatedAt"
            ])
        )
        || isHC();

      allow delete: if false;
    }

    match /permissions/{permissionId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isHC()
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "PENDING";

      allow update: if isHC()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "status",
            "reviewedBy",
            "reviewerName",
            "reviewNote",
            "reviewedAt",
            "updatedAt"
          ]);

      allow delete: if false;
    }

    match /working_reports/{reportId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isHC()
        );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isHC()
        );

      allow create, update: if isHC();
      allow delete: if false;
    }
  }
}
