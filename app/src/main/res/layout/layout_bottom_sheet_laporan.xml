<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#161D2F"
    android:orientation="vertical"
    android:padding="24dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#4A5568" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Buat Laporan Kerja"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Tanggal"
        android:textColor="#8B95A5"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etTanggalLaporan"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input_outline"
        android:paddingHorizontal="16dp"
        android:hint="Pilih tanggal"
        android:textColorHint="#4A5568"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:focusable="false"
        android:clickable="true"
        android:cursorVisible="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Judul Aktivitas"
        android:textColor="#8B95A5"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etJudulLaporan"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input_outline"
        android:hint="cth. Maintenance Server Produksi"
        android:paddingHorizontal="16dp"
        android:textColor="@android:color/white"
        android:textColorHint="#4A5568"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Deskripsi Pekerjaan"
        android:textColor="#8B95A5"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etDeskripsiLaporan"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input_outline"
        android:gravity="top|start"
        android:hint="Ceritakan apa yang dikerjakan hari ini..."
        android:padding="16dp"
        android:textColor="@android:color/white"
        android:textColorHint="#4A5568"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Durasi Kerja"
        android:textColor="#8B95A5"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <EditText
            android:id="@+id/etJamMulai"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_outline"
            android:gravity="center"
            android:hint="Jam mulai"
            android:textColor="@android:color/white"
            android:textColorHint="#4A5568"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"/>

        <EditText
            android:id="@+id/etJamSelesai"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_outline"
            android:gravity="center"
            android:hint="Jam selesai"
            android:textColor="@android:color/white"
            android:textColorHint="#4A5568"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Lampiran (opsional)"
        android:textColor="#8B95A5"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tabFileLaporan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1E3A8A"
            app:cardCornerRadius="8dp"
            app:strokeColor="#2D3548"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📄 File"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tabFotoLaporan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#222831"
            app:cardCornerRadius="8dp"
            app:strokeColor="#2D3548"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📷 Foto"
                android:textColor="#8B95A5"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tabLinkLaporan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#222831"
            app:cardCornerRadius="8dp"
            app:strokeColor="#2D3548"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🔗 Link Drive"
                android:textColor="#8B95A5"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/boxUploadLaporan"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_dashed_box_rect"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvUploadHintLaporan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Tarik file/screenshot di sini atau pilih file"
            android:textColor="#8B95A5"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etLinkDriveLaporan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:hint="Tempel link Google Drive di sini..."
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/white"
            android:textColorHint="#4A5568"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btnKirimLaporan"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/bg_btn_gradient_absen"
        android:text="Kirim Laporan"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:backgroundTint="@null" />

</LinearLayout>